const DIM = 3, MLP_H = 128, CTX = 32, EPOCHS = 100, LR = 0.003;

function buildModel(Vw, Vt) {
const h = (r, c) => { const w = new Float64Array(r * c); const sc = Math.sqrt(2 / c); for (let i = 0; i < w.length; i++) w[i] = randn() * sc; return w; };
const sm = (r, c) => { const w = new Float64Array(r * c); for (let i = 0; i < w.length; i++) w[i] = randn() * 0.02; return w; };
const z = n => new Float64Array(n);
return {
E: h(Vt, DIM), mE: z(Vt*DIM), vE: z(Vt*DIM),
Wq: sm(DIM,DIM), mWq: z(DIM*DIM), vWq: z(DIM*DIM),
Wk: sm(DIM,DIM), mWk: z(DIM*DIM), vWk: z(DIM*DIM),
Wv: sm(DIM,DIM), mWv: z(DIM*DIM), vWv: z(DIM*DIM),
Wo: sm(DIM,DIM), mWo: z(DIM*DIM), vWo: z(DIM*DIM),
W1: h(DIM,MLP_H), mW1: z(DIM*MLP_H), vW1: z(DIM*MLP_H), b1: z(MLP_H), mb1: z(MLP_H), vb1: z(MLP_H),
W2: h(MLP_H,DIM), mW2: z(MLP_H*DIM), vW2: z(MLP_H*DIM), b2: z(DIM), mb2: z(DIM), vb2: z(DIM),
Wp: sm(DIM,Vw), mWp: z(DIM*Vw), vWp: z(DIM*Vw),
