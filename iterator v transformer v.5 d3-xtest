};
}

function smx(arr, n) {
let mx = -Infinity; for (let i = 0; i < n; i++) if (arr[i] > mx) mx = arr[i];
let s = 0; const o = new Float64Array(n);
for (let i = 0; i < n; i++) { o[i] = Math.exp(arr[i] - mx); s += o[i]; }
for (let i = 0; i < n; i++) o[i] /= s;
return o;
}

function adam(p, g, m, v, t, lr) {
const b1=0.9, b2=0.999, eps=1e-8, bc1=1-b1**t, bc2=1-b2**t;
for (let i = 0; i < p.length; i++) {
const gi = Math.max(-1, Math.min(1, g[i]));
m[i] = b1*m[i]+(1-b1)*gi; v[i] = b2*v[i]+(1-b2)*gi*gi;
p[i] -= lr*(m[i]/bc1)/(Math.sqrt(v[i]/bc2)+eps);
}
}

