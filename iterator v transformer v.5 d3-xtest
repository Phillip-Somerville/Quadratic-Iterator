// ── Build token sequences ─────────────────────────────────────────
function buildData(text) {
const s = text.toLowerCase();
const words = s.match(/[a-z’]+/g) || [];
const triplets = [];
for (let i = 0; i + 3 <= s.length; i += 3) triplets.push(s.slice(i, i + 3));
const digests = words.map(w => dStar(textBits(w)));
const bits = textBits(s);
const quad = quadChannel(encodeF(bits));
const wordEndSet = new Set();
let charPos = 0;
for (const w of words) { charPos += w.length; wordEndSet.add(Math.floor(charPos / 3)); charPos++; }
function tripletWord(ti) {
let cp = ti * 3, cumul = 0;
for (let wi = 0; wi < words.length; wi++) { cumul += words[wi].length + 1; if (cp < cumul) return wi; }
return words.length - 1;
}
function nextWord(ti) {
const cp = (ti + 1) * 3; let cumul = 0;
for (let wi = 0; wi < words.length; wi++) { cumul += words[wi].length + 1; if (cp <= cumul) return Math.min(wi + 1, words.length - 1); }
return words.length - 1;
}
const N = triplets.length;
const iterX = [];
for (let ti = 0; ti < N; ti++) {
const chunk = quad.slice(ti * 24, Math.min((ti + 1) * 24, quad.length));
const len = chunk.length || 1;
const mb0 = chunk.reduce((a, q) => a + q[0], 0) / len;
const mb1 = chunk.reduce((a, q) => a + q[1], 0) / len;
const wi = tripletWord(ti);
const d = wordEndSet.has(ti) ? digests[Math.min(wi, digests.length - 1)] : 0.0;
iterX.push([mb0, mb1, d]);
}
const targets = Array.from({ length: N }, (_, ti) => nextWord(ti));
return { triplets, iterX, targets, words, N };
}

