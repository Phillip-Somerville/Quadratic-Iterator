<div class="glass jstream-wrap section-gap">
  <div class="card-head">
    <span class="card-label">J-Stream Visualiser</span>
    <span class="card-meta" id="vis-meta"></span>
  </div>
  <div class="jstream-scroll">
    <div class="jstream-bars" id="jbars"></div>
  </div>
  <div class="jstream-footer">
    <div class="legend">
