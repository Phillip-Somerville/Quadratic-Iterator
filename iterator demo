<script>
var C_STATIC = 1.094, DELTA = 0.002, PREC = 14;
var SCALE = Math.pow(10, PREC);

function truncRound(x) {
var r = parseFloat(x.toFixed(PREC));
return r >= 0 ? Math.floor(r * SCALE) / SCALE : Math.ceil(r * SCALE) / SCALE;
}

function encodeNode(payload, seed) {
var bits = [], ci, code, byteLen, b, byte_, i;
for (ci = 0; ci < payload.length; ci++) {
code    = payload.codePointAt(ci);
byteLen = Math.max(1, Math.ceil(Math.log2(code + 1) / 8));
for (b = byteLen - 1; b >= 0; b–) {
byte_ = (code >> (b * 8)) & 0xff;
for (i = 7; i >= 0; i–) bits.push((byte_ >> i) & 1);
}
}
var bSeq = bits.concat([0, 0]);
var N    = bSeq.length;
var FSeq = [], n;
for (n = 0; n < N; n++) FSeq.push(C_STATIC + (bSeq[n] ? DELTA : 0));

var H = new Array(N + 1);
H[0] = seed;
for (n = 0; n < N; n++) {
var F = FSeq[n];
H[n+1] = truncRound((H[n]*H[n] - F)*(H[n]*H[n] - F) - F);
}

var J = [], steps = [], Fp, Hn1, Hn2, inner, val2, k, diff, j;
for (n = 1; n <= N; n++) {
Fp    = FSeq[n-1];
Hn1   = H[n];
Hn2   = H[n-1];
inner = Hn1 + Fp;
k = null; diff = null; j = 0;
if (inner >= 0) {
val2 = Fp - Math.sqrt(inner);
if (val2 >= 0) {
k    = truncRound(Math.sqrt(val2));
diff = k - Hn2;
j    = diff === 0 ? 0 : (diff > 0 ? 1 : -1);
} else {
diff = Hn1 - Hn2;
j    = diff >= 0 ? 1 : -1;
}
} else {
diff = Hn1 - Hn2;
j    = diff >= 0 ? 1 : -1;
}
J.push(j);
steps.push({ n:n, H_nm2:Hn2, H_nm1:Hn1, k:k, diff:diff, j:j });
}
return { digest:H[N], J:J, N:J.length, steps:steps };
}

function autocorr(J) {
var s = 0, n = J.length - 1;
for (var i = 0; i < n; i++) s += J[i] * J[i+1];
return s / n;
}

function downsample(arr, target) {
var out = [], step = arr.length / target;
for (var i = 0; i < target; i++) out.push(arr[Math.floor(i * step)]);
return out;
}

function fmtExp(x) {
if (x === null) return ‘\u2014’;
if (x === 0)   return ‘0’;
return x.toExponential(4);
}

function esc(s) {
return s.replace(/&/g,’&’).replace(/</g,’<’).replace(/>/g,’>’);
}

var hist = [];

function addHist(payload, digest, J) {
if (hist.length && hist[0].payload === payload) return;
hist.unshift({ payload:payload, digest:digest, J:J });
if (hist.length > 10) hist.pop();
renderHist();
}

function renderHist() {
document.getElementById(‘history-section’).style.display = ‘block’;
var list = document.getElementById(‘history-list’);
list.innerHTML = ‘’;
for (var i = 0; i < hist.length; i++) {
(function(h) {
var el  = document.createElement(‘div’);
el.className = ‘hitem’;
var s   = h.J.length > 140 ? downsample(h.J, 140) : h.J;
var bars = ‘’;
for (var x = 0; x < s.length; x++)
bars += ‘<div class="hbar ' + (s[x]===1?'pos':s[x]===-1?'neg':'zero') + '"></div>’;
el.innerHTML =
‘<div class="hpayload">’ + esc(h.payload) + ‘</div>’ +
‘<div class="hdigest">’  + h.digest.toFixed(14) + ‘</div>’ +
‘<div class="hmini">’    + bars + ‘</div>’;
el.addEventListener(‘click’, function() {
document.getElementById(‘payload’).value = h.payload;
runSilent();
});
list.appendChild(el);
})(hist[i]);
}
}

function renderOutput(digest, J, N, steps, seed) {
document.getElementById(‘digest-val’).textContent = digest.toFixed(14);
document.getElementById(‘badge-n’).textContent    = N + ’ symbols’;
document.getElementById(‘stat-n’).textContent     = N;
document.getElementById(‘stat-seed’).textContent  = seed.toFixed(3);

var barsEl = document.getElementById(‘jbars’);
barsEl.innerHTML = ‘’;
var sample = J.length > 900 ? downsample(J, 900) : J;
for (var i = 0; i < sample.length; i++) {
var d = document.createElement(‘div’);
d.className = ‘jbar ’ + (sample[i]===1?‘pos’:sample[i]===-1?‘neg’:‘zero’);
barsEl.appendChild(d);
}
document.getElementById(‘vis-meta’).textContent =
sample.length < J.length ? sample.length+’ of ‘+J.length+’ shown’ : J.length+’ symbols’;

document.getElementById(‘raw-meta’).textContent = J.length + ’ symbols’;
var raw = ‘’;
for (var i = 0; i < J.length; i++)
raw += J[i]===1 ? ‘<span class="p">+</span>’ : J[i]===-1 ? ‘<span class="n">\u2212</span>’ : ‘<span class="z">\u00b7</span>’;
document.getElementById(‘jraw’).innerHTML = raw;

var nPos=0, nNeg=0, nZero=0;
for (var i = 0; i < J.length; i++) {
if (J[i]===1) nPos++; else if (J[i]===-1) nNeg++; else nZero++;
}
document.getElementById(‘zero-rate’).textContent = (nZero/N*100).toFixed(1) + ‘% closure’;
document.getElementById(‘stats-grid’).innerHTML =
‘<div class="stat-cell"><div class="stat-label">+1</div><div class="stat-val" style="color:var(--pos)">’+nPos+’</div></div>’+
‘<div class="stat-cell"><div class="stat-label">\u22121</div><div class="stat-val" style="color:var(--neg)">’+nNeg+’</div></div>’+
‘<div class="stat-cell"><div class="stat-label">0 closure</div><div class="stat-val" style="color:var(--zero)">’+nZero+’</div></div>’+
‘<div class="stat-cell"><div class="stat-label">Balance</div><div class="stat-val">’+((nPos-nNeg)/N).toFixed(3)+’</div></div>’+
‘<div class="stat-cell"><div class="stat-label">Density</div><div class="stat-val">’+((nPos+nNeg)/N*100).toFixed(1)+’%</div></div>’;

var ac = autocorr(J);
var fe = document.getElementById(‘autocorr-fill’);
fe.className   = ’autocorr-fill ’ + (ac < 0 ? ‘neg’ : ‘pos’);
fe.style.width = (Math.abs(ac) * 50) + ‘%’;
document.getElementById(‘autocorr-val’).textContent = ac.toFixed(4);

var tbody = document.getElementById(‘step-tbody’);
tbody.innerHTML = ‘’;
var shown = steps.length > 200 ? steps.slice(0,200) : steps;
for (var i = 0; i < shown.length; i++) {
var s  = shown[i];
var tr = document.createElement(‘tr’);
tr.className = s.j===0?‘zero-row’:s.j>0?‘pos-row’:‘neg-row’;
tr.innerHTML =
‘<td>’+s.n+’</td>’+
‘<td>’+s.H_nm2.toFixed(14)+’</td>’+
‘<td>’+s.H_nm1.toFixed(14)+’</td>’+
‘<td>’+(s.k!==null?s.k.toFixed(14):’\u2014’)+’</td>’+
‘<td>’+fmtExp(s.diff)+’</td>’+
‘<td class="j-cell">’+(s.j===0?‘0’:s.j>0?’+1’:’\u22121’)+’</td>’;
tbody.appendChild(tr);
}
if (steps.length > 200) {
var tr2 = document.createElement(‘tr’);
tr2.innerHTML = ‘<td colspan="6" style="text-align:center;color:var(--dim);padding:10px">\u2026 ‘+(steps.length-200)+’ more steps</td>’;
tbody.appendChild(tr2);
}

document.getElementById(‘output’).classList.add(‘visible’);
}

function runSilent() {
var payload = document.getElementById(‘payload’).value;
var seed    = parseFloat(document.getElementById(‘seed’).value) || 0.087;
if (!payload) return;
var r = encodeNode(payload, seed);
renderOutput(r.digest, r.J, r.N, r.steps, seed);
}

function run() {
var payload = document.getElementById(‘payload’).value;
var seed    = parseFloat(document.getElementById(‘seed’).value) || 0.087;
if (!payload) return;
var r = encodeNode(payload, seed);
renderOutput(r.digest, r.J, r.N, r.steps, seed);
addHist(payload, r.digest, r.J);
}

document.getElementById(‘btn-run’).addEventListener(‘click’, run);
document.getElementById(‘btn-clear’).addEventListener(‘click’, function() {
document.getElementById(‘payload’).value = ‘’;
document.getElementById(‘output’).classList.remove(‘visible’);
});
document.getElementById(‘btn-clear-hist’).addEventListener(‘click’, function() {
hist = [];
document.getElementById(‘history-list’).innerHTML = ‘’;
});
document.getElementById(‘payload’).addEventListener(‘keydown’, function(e) {
if ((e.ctrlKey || e.metaKey) && e.key === ‘Enter’) run();
});
</script>

