<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quadratic Iterator Demo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@200;300;400;500;600&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ── Design tokens ────────────────────────────────────────────────── */
:root {
  /* glass palette */
  --glass-bg:       rgba(255,255,255,0.12);
  --glass-bg-2:     rgba(255,255,255,0.07);
  --glass-bg-3:     rgba(255,255,255,0.18);
  --glass-border:   rgba(255,255,255,0.30);
  --glass-border-2: rgba(255,255,255,0.15);
  --glass-shine:    rgba(255,255,255,0.55);
  --glass-inset:    rgba(0,0,0,0.08);
  --blur:           saturate(180%) blur(28px);
  --blur-light:     saturate(140%) blur(16px);

/* scene */
–scene-1: #0d1f2e;
–scene-2: #0e2a3d;
–scene-3: #0a1a28;

/* accents — powder sky palette */
–blue:   #87ceeb;
–blue-2: #5bb8d4;
–red:    #f08080;
–purple: #9eb8d9;
–green:  #7ec8b0;
–yellow: #b8d9e8;

/* text */
–text-1: rgba(225,242,252,0.93);
–text-2: rgba(185,220,242,0.60);
–text-3: rgba(155,200,230,0.35);

–mono: ‘JetBrains Mono’, monospace;
–serif: ‘Instrument Serif’, Georgia, serif;
–sans: -apple-system, ‘SF Pro Display’, ‘Helvetica Neue’, sans-serif;

–r-sm: 14px;
–r-md: 18px;
–r-lg: 24px;
–r-xl: 32px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
font-family: var(–sans);
font-size: 13px;
line-height: 1.5;
color: var(–text-1);
min-height: 100vh;
overflow-x: hidden;
-webkit-font-smoothing: antialiased;
}

/* ── Scene background ─────────────────────────────────────────────── */
.scene {
position: fixed; inset: 0; z-index: -1;
background:
radial-gradient(ellipse 80% 60% at 20% 10%, rgba(80,160,210,0.45) 0%, transparent 60%),
radial-gradient(ellipse 60% 80% at 80% 90%, rgba(40,110,160,0.50) 0%, transparent 60%),
radial-gradient(ellipse 100% 50% at 50% 50%, rgba(10,40,70,0.85) 0%, transparent 100%),
linear-gradient(160deg, #0d1f2e 0%, #0e2a3d 50%, #0a1a28 100%);
}

.orb {
position: absolute;
border-radius: 50%;
filter: blur(80px);
pointer-events: none;
animation: orbDrift 20s ease-in-out infinite;
}
.orb-1 {
width: 600px; height: 400px;
background: radial-gradient(ellipse, rgba(135,206,235,0.15) 0%, transparent 70%);
top: -100px; left: -100px;
}
.orb-2 {
width: 500px; height: 500px;
background: radial-gradient(ellipse, rgba(91,184,212,0.10) 0%, transparent 70%);
bottom: -150px; right: -100px;
animation-delay: -8s; animation-duration: 25s;
}
.orb-3 {
width: 300px; height: 300px;
background: radial-gradient(ellipse, rgba(158,184,217,0.10) 0%, transparent 70%);
top: 50%; left: 50%;
animation-delay: -4s; animation-duration: 18s;
}
@keyframes orbDrift {
0%,100% { transform: translate(0,0) scale(1); }
33% { transform: translate(40px,-30px) scale(1.05); }
66% { transform: translate(-30px,40px) scale(0.95); }
}

/* ── Shell ────────────────────────────────────────────────────────── */
.shell {
max-width: 860px;
margin: 0 auto;
padding: 72px 24px 120px;
}

/* ── Glass mixin ──────────────────────────────────────────────────── */
.glass {
background: var(–glass-bg);
backdrop-filter: var(–blur);
-webkit-backdrop-filter: var(–blur);
border: 1px solid var(–glass-border);
border-radius: var(–r-lg);
position: relative;
overflow: hidden;
}
.glass::before {
content: ‘’;
position: absolute;
inset: 0;
border-radius: inherit;
background: linear-gradient(135deg, var(–glass-shine) 0%, transparent 45%);
opacity: 0.25;
pointer-events: none;
}
.glass::after {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(–glass-shine) 40%, var(–glass-shine) 60%, transparent);
opacity: 0.6;
pointer-events: none;
}

/* ── Header ───────────────────────────────────────────────────────── */
header {
margin-bottom: 48px;
animation: fadeUp 0.8s ease both;
}
.eyebrow {
font-size: 10px;
font-weight: 500;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–blue);
margin-bottom: 12px;
display: flex;
align-items: center;
gap: 8px;
}
.eyebrow::before {
content: ‘’;
width: 24px; height: 1px;
background: linear-gradient(90deg, transparent, var(–blue));
}
.title {
font-size: 52px;
font-weight: 200;
letter-spacing: -0.03em;
color: var(–text-1);
line-height: 1.05;
margin-bottom: 12px;
}
.title strong {
font-weight: 500;
background: linear-gradient(135deg, #e1f2fc 0%, rgba(135,206,235,0.95) 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}
.tagline {
font-family: var(–mono);
font-size: 11px;
color: var(–text-2);
font-weight: 300;
line-height: 1.8;
}

/* ── Input card ───────────────────────────────────────────────────── */
.input-card {
margin-bottom: 14px;
animation: fadeUp 0.8s 0.1s ease both;
}

.card-head {
display: flex;
align-items: center;
justify-content: space-between;
padding: 14px 20px;
border-bottom: 1px solid var(–glass-border-2);
}
.card-label {
font-size: 10px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-2);
}
.card-meta {
font-family: var(–mono);
font-size: 11px;
color: var(–text-3);
}

textarea {
display: block;
width: 100%;
background: transparent;
border: none;
outline: none;
color: var(–text-1);
font-family: var(–serif);
font-size: 18px;
line-height: 1.65;
resize: none;
min-height: 80px;
padding: 22px 22px 18px;
caret-color: var(–blue);
}
textarea::placeholder {
color: var(–text-3);
font-style: italic;
}

.controls {
display: flex;
align-items: center;
gap: 10px;
padding: 14px 20px;
border-top: 1px solid var(–glass-border-2);
background: var(–glass-bg-2);
}

.btn-primary {
background: linear-gradient(135deg, rgba(91,184,212,0.85) 0%, rgba(60,140,180,0.85) 100%);
border: 1px solid rgba(135,206,235,0.4);
border-radius: 10px;
color: #fff;
font-family: var(–sans);
font-size: 13px;
font-weight: 500;
padding: 9px 22px;
cursor: pointer;
transition: all 0.2s;
backdrop-filter: blur(8px);
box-shadow: 0 2px 12px rgba(91,184,212,0.30), inset 0 1px 0 rgba(255,255,255,0.2);
letter-spacing: 0.01em;
}
.btn-primary:hover {
background: linear-gradient(135deg, rgba(135,206,235,0.90) 0%, rgba(91,184,212,0.90) 100%);
box-shadow: 0 4px 20px rgba(135,206,235,0.40), inset 0 1px 0 rgba(255,255,255,0.25);
transform: translateY(-1px);
}
.btn-primary:active { transform: translateY(0); }

.btn-ghost {
background: var(–glass-bg-2);
border: 1px solid var(–glass-border-2);
border-radius: 10px;
color: var(–text-2);
font-family: var(–sans);
font-size: 12px;
padding: 8px 16px;
cursor: pointer;
transition: all 0.2s;
backdrop-filter: blur(8px);
}
.btn-ghost:hover {
background: var(–glass-bg-3);
color: var(–text-1);
border-color: var(–glass-border);
}

.seed-row {
display: flex;
align-items: center;
gap: 8px;
margin-left: auto;
color: var(–text-3);
font-size: 11px;
font-family: var(–mono);
}
.seed-row input {
background: var(–glass-inset);
border: 1px solid var(–glass-border-2);
border-radius: 8px;
color: var(–text-1);
font-family: var(–mono);
font-size: 12px;
padding: 5px 10px;
width: 100px;
outline: none;
transition: border-color 0.2s, box-shadow 0.2s;
}
.seed-row input:focus {
border-color: rgba(79,168,255,0.5);
box-shadow: 0 0 0 3px rgba(10,132,255,0.15);
}

/* ── Output ───────────────────────────────────────────────────────── */
.output { display: none; }
.output.visible { display: block; }

/* ── Digest hero ──────────────────────────────────────────────────── */
.digest-hero {
margin-bottom: 14px;
padding: 28px;
animation: fadeUp 0.5s ease both;
}
.digest-top {
display: flex;
align-items: flex-start;
justify-content: space-between;
gap: 16px;
margin-bottom: 20px;
}
.digest-label {
font-size: 10px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-2);
margin-bottom: 8px;
}
.digest-number {
font-family: var(–mono);
font-size: 24px;
font-weight: 300;
color: var(–blue);
letter-spacing: -0.02em;
text-shadow: 0 0 30px rgba(135,206,235,0.35);
}
.badge {
flex-shrink: 0;
background: linear-gradient(135deg, rgba(135,206,235,0.12), rgba(91,184,212,0.07));
border: 1px solid rgba(135,206,235,0.22);
border-radius: 20px;
padding: 6px 16px;
font-size: 12px;
font-weight: 500;
color: var(–blue);
white-space: nowrap;
backdrop-filter: blur(8px);
}
.digest-stats {
display: flex;
gap: 28px;
padding-top: 20px;
border-top: 1px solid var(–glass-border-2);
}
.dstat {
border-left: 2px solid rgba(135,206,235,0.18);
padding-left: 14px;
}
.dstat-label {
font-size: 9px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-3);
margin-bottom: 4px;
}
.dstat-val {
font-family: var(–mono);
font-size: 15px;
color: var(–text-1);
font-weight: 300;
}

/* ── J-stream visualiser ──────────────────────────────────────────── */
.jstream-wrap {
margin-bottom: 14px;
overflow: hidden;
animation: fadeUp 0.5s 0.05s ease both;
}
.jstream-scroll {
overflow-x: auto;
padding: 22px 22px 14px;
scrollbar-width: thin;
scrollbar-color: rgba(255,255,255,0.1) transparent;
}
.jstream-bars {
display: flex;
align-items: center;
gap: 2.5px;
height: 56px;
min-width: min-content;
}
.jbar {
width: 5px;
border-radius: 2.5px;
flex-shrink: 0;
transition: opacity 0.2s;
}
.jbar.pos  {
background: linear-gradient(180deg, var(–blue) 0%, rgba(10,132,255,0.6) 100%);
height: 100%;
box-shadow: 0 0 6px rgba(79,168,255,0.3);
}
.jbar.neg  {
background: linear-gradient(180deg, var(–red) 0%, rgba(255,69,58,0.6) 100%);
height: 100%;
box-shadow: 0 0 6px rgba(255,69,58,0.3);
}
.jbar.zero {
background: linear-gradient(180deg, var(–purple) 0%, rgba(191,90,242,0.6) 100%);
height: 50%;
box-shadow: 0 0 6px rgba(191,90,242,0.3);
}
.jstream-footer {
display: flex;
align-items: center;
justify-content: space-between;
padding: 12px 22px 14px;
border-top: 1px solid var(–glass-border-2);
background: var(–glass-bg-2);
flex-wrap: wrap;
gap: 8px;
}
.legend { display: flex; gap: 18px; }
.litem  { display: flex; align-items: center; gap: 7px; font-size: 11px; color: var(–text-2); }
.ldot   { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

/* ── Raw ternary ──────────────────────────────────────────────────── */
.jraw {
font-family: var(–mono);
font-size: 11.5px;
line-height: 2.2;
word-break: break-all;
max-height: 115px;
overflow-y: auto;
color: var(–text-3);
padding: 18px 22px;
scrollbar-width: thin;
scrollbar-color: rgba(255,255,255,0.1) transparent;
}
.jraw .p { color: var(–blue); font-weight: 500; }
.jraw .n { color: var(–red); font-weight: 500; }
.jraw .z { color: var(–purple); }

/* ── Stats grid ───────────────────────────────────────────────────── */
.stats-grid {
display: grid;
grid-template-columns: repeat(5, 1fr);
gap: 8px;
margin-bottom: 14px;
animation: fadeUp 0.5s 0.1s ease both;
}
.stat-cell {
background: var(–glass-bg);
backdrop-filter: var(–blur-light);
-webkit-backdrop-filter: var(–blur-light);
border: 1px solid var(–glass-border-2);
border-radius: var(–r-md);
padding: 16px 12px;
text-align: center;
position: relative;
overflow: hidden;
transition: transform 0.2s, box-shadow 0.2s;
}
.stat-cell:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
.stat-cell::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0; height: 1px;
background: linear-gradient(90deg, transparent, var(–glass-shine) 50%, transparent);
opacity: 0.4;
}
.stat-label {
font-size: 9px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-3);
margin-bottom: 8px;
}
.stat-val { font-family: var(–mono); font-size: 18px; font-weight: 300; }

/* ── Autocorrelation ──────────────────────────────────────────────── */
.autocorr-card {
margin-bottom: 14px;
padding: 20px 22px;
display: grid;
grid-template-columns: 180px 1fr 90px;
align-items: center;
gap: 18px;
animation: fadeUp 0.5s 0.15s ease both;
}
.autocorr-label {
font-size: 11px;
font-weight: 600;
letter-spacing: 0.06em;
text-transform: uppercase;
color: var(–text-2);
}
.autocorr-track {
height: 6px;
background: rgba(255,255,255,0.06);
border-radius: 3px;
position: relative;
overflow: hidden;
border: 1px solid var(–glass-border-2);
}
.autocorr-fill {
position: absolute;
top: 0; height: 100%;
border-radius: 3px;
transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
}
.autocorr-fill.neg { background: linear-gradient(90deg, var(–red), rgba(240,128,128,0.4)); right: 50%; }
.autocorr-fill.pos { background: linear-gradient(90deg, rgba(91,184,212,0.4), var(–blue)); left: 50%; }
.autocorr-val {
font-family: var(–mono);
font-size: 16px;
font-weight: 300;
text-align: right;
}

/* ── Step table ───────────────────────────────────────────────────── */
.step-wrap {
animation: fadeUp 0.5s 0.2s ease both;
}
.step-table-wrap {
max-height: 230px;
overflow-y: auto;
scrollbar-width: thin;
scrollbar-color: rgba(255,255,255,0.1) transparent;
}
table {
width: 100%;
border-collapse: collapse;
}
th {
font-size: 9px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-3);
text-align: left;
padding: 10px 16px;
border-bottom: 1px solid var(–glass-border-2);
position: sticky;
top: 0;
background: rgba(13,42,61,0.88);
backdrop-filter: blur(20px);
-webkit-backdrop-filter: blur(20px);
}
td {
font-family: var(–mono);
font-size: 11px;
font-weight: 300;
padding: 5px 16px;
border-bottom: 1px solid rgba(255,255,255,0.03);
}
tr.zero-row td { color: var(–purple); }
tr.pos-row  td { color: rgba(255,255,255,0.65); }
tr.neg-row  td { color: rgba(255,255,255,0.65); }
tr.pos-row td.j-cell  { color: var(–blue); font-weight: 500; }
tr.neg-row td.j-cell  { color: var(–red);  font-weight: 500; }
tr.zero-row td.j-cell { color: var(–purple); font-weight: 500; }
tr:hover td { background: rgba(255,255,255,0.025); }

/* ── History ──────────────────────────────────────────────────────── */
.history {
margin-top: 48px;
animation: fadeUp 0.6s ease both;
}
.history-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 16px;
padding: 0 4px;
}
.history-label {
font-size: 10px;
font-weight: 600;
letter-spacing: 0.14em;
text-transform: uppercase;
color: var(–text-2);
display: flex;
align-items: center;
gap: 8px;
}
.history-label::before {
content: ‘’;
width: 16px; height: 1px;
background: linear-gradient(90deg, transparent, var(–text-3));
}
.history-scroll {
max-height: 420px;
overflow-y: auto;
scrollbar-width: thin;
scrollbar-color: rgba(255,255,255,0.08) transparent;
}
.hitem {
background: var(–glass-bg-2);
backdrop-filter: var(–blur-light);
-webkit-backdrop-filter: var(–blur-light);
border: 1px solid var(–glass-border-2);
border-radius: var(–r-md);
padding: 16px 20px;
margin-bottom: 10px;
cursor: pointer;
transition: all 0.2s;
position: relative;
overflow: hidden;
}
.hitem::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0; height: 1px;
background: linear-gradient(90deg, transparent, var(–glass-shine) 50%, transparent);
opacity: 0.3;
transition: opacity 0.2s;
}
.hitem:hover {
background: var(–glass-bg);
border-color: var(–glass-border);
transform: translateY(-1px);
box-shadow: 0 8px 28px rgba(0,0,0,0.25);
}
.hitem:hover::before { opacity: 0.5; }
.hpayload {
font-family: var(–serif);
font-size: 15px;
color: var(–text-1);
word-break: break-word;
margin-bottom: 7px;
}
.hdigest {
font-family: var(–mono);
font-size: 10.5px;
color: rgba(135,206,235,0.60);
margin-bottom: 8px;
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
}
.hmini { display: flex; gap: 1.5px; align-items: center; height: 12px; overflow: hidden; }
.hbar  { width: 3px; height: 100%; border-radius: 1px; flex-shrink: 0; }
.hbar.pos  { background: var(–blue); opacity: 0.65; }
.hbar.neg  { background: var(–red); opacity: 0.65; }
.hbar.zero { background: var(–purple); height: 50%; opacity: 0.65; }

/* ── Divider between sections ─────────────────────────────────────── */
.section-gap { margin-bottom: 14px; }

/* ── Animations ───────────────────────────────────────────────────── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(16px); }
to   { opacity: 1; transform: none; }
}

/* ── Scrollbar global ─────────────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.22); }

/* ── Responsive ───────────────────────────────────────────────────── */
@media (max-width: 600px) {
.title { font-size: 36px; }
.stats-grid { grid-template-columns: repeat(3,1fr); }
.autocorr-card { grid-template-columns: 1fr; gap: 10px; }
.digest-stats { flex-wrap: wrap; gap: 16px; }
}
</style>

</head>
