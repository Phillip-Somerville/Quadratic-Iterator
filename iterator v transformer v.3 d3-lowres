for (let d=0;d<DIM;d++) { let s=model.b2[d]; for (let j=0;j<MLP_H;j++) s+=h1[i*MLP_H+j]*model.W2[j*DIM+d]; h2[i*DIM+d]=s+h[i*DIM+d]; }
}
// logits + loss
const tgt = targets.slice(start, start+CTX);
const probs = [];
let bLoss = 0;
for (let i=0;i<CTX;i++) {
const lg=new Float64Array(Vw);
for (let v=0;v<Vw;v++) { let s=0; for (let d=0;d<DIM;d++) s+=h2[i*DIM+d]*model.Wp[d*Vw+v]; lg[v]=s; }
const p=smx(lg,Vw); probs.push(p);
