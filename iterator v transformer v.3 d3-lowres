const gWq=train?new Float64Array(DIM*DIM):null, gWk=train?new Float64Array(DIM*DIM):null;
const gWv=train?new Float64Array(DIM*DIM):null, gWo=train?new Float64Array(DIM*DIM):null;
const gW1=train?new Float64Array(DIM*MLP_H):null, gb1=train?new Float64Array(MLP_H):null;
const gW2=train?new Float64Array(MLP_H*DIM):null, gb2=train?new Float64Array(DIM):null;
const gWp=train?new Float64Array(DIM*Vw):null;

for (let start = 0; start + CTX < N; start += stride) {
// build X
const X = new Float64Array(CTX * DIM);
for (let i = 0; i < CTX; i++) {
const si = start + i;
if (useFixed) { X[i*DIM]=iterX[si][0]; X[i*DIM+1]=iterX[si][1]; X[i*DIM+2]=iterX[si][2]; }
else { const id=triIds[si]; X[i*DIM]=model.E[id*DIM]; X[i*DIM+1]=model.E[id*DIM+1]; X[i*DIM+2]=model.E[id*DIM+2]; }
