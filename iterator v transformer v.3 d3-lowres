…(curves.trC||[]),
…(curves.teC||[]),
…(curves.trA||[]),
…(curves.teA||[]),
…(curves.trR||[]),
…(curves.teR||[]),
];
if (!all.length) return {minL:0, maxL:7};
const raw = Math.max(…all);
return {
minL: 0,
maxL: Math.max(raw * 1.12, 6.5),
};
};

const renderChart = (trainMode) => {
const keys = trainMode
? {C:curves.trC, A:curves.trA, R:curves.trR}
: {C:curves.teC, A:curves.teA, R:curves.teR};
if (!keys.C?.length) return null;
const W=320, H=280, PL=42, PR=12, PT=16, PB=36;
const cW=W-PL-PR, cH=H-PT-PB;
const {minL, maxL} = globalMinMax();
const n=keys.C.length;
const xS=i=>PL+(i/Math.max(n-1,1))*cW;
const yS=v=>PT+(1-(v-minL)/(maxL-minL+1e-9))*cH;
const path=(data,color)=>{
if (!data?.length) return null;
const d=data.map((v,i)=>`${i===0?'M':'L'}${xS(i).toFixed(1)},${yS(v).toFixed(1)}`).join(’ ’);
return <path d={d} fill="none" stroke={color} strokeWidth="2" strokeLinecap="round"/>;
};
const logVw=finals?.logVw||Math.log(136);
const yTicks=[0,1,2,3,4,5,6,7].filter(v=>v<=maxL+0.1).map(v=>{
const y=yS(v);
return <g key={v}>
<line x1={PL} y1={y} x2={PL+cW} y2={y} stroke="#efefef"/>
<text x={PL-4} y={y+4} textAnchor="end" fontSize="8" fill="#c0c8d0" fontFamily="system-ui">{v}</text>
</g>;
});
const xTicks=[20,40,60,80,100].map(e=>e<=n?<g key={e}>
<line x1={xS(e-1)} y1={PT} x2={xS(e-1)} y2={PT+cH} stroke="#f3f3f3"/>
<text x={xS(e-1)} y={PT+cH+13} textAnchor="middle" fontSize="8" fill="#c0c8d0" fontFamily="system-ui">{e}</text>
</g>:null);
return (
<svg width={W} height={H} style={{display:‘block’,width:‘100%’,height:‘auto’}}>
