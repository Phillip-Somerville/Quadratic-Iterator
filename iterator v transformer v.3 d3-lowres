// ── Build token sequences ─────────────────────────────────────────
function buildData(text) {
const s = text.toLowerCase();
const words = s.match(/[a-z’]+/g) || [];
const triplets = [];
for (let i = 0; i + 3 <= s.length; i += 3) triplets.push(s.slice(i, i + 3));
const digests = words.map(w => dStar(textBits(w)));
const bits = textBits(s);
const quad = quadChannel(encodeF(bits));
const wordEndSet = new Set();
let charPos = 0;
for (const w of words) { charPos += w.length; wordEndSet.add(Math.floor(charPos / 3)); charPos++; }
function tripletWord(ti) {
let cp = ti * 3, cumul = 0;
for (let wi = 0; wi < words.length; wi++) { cumul += words[wi].length + 1; if (cp < cumul) return wi; }
return words.length - 1;
}
function nextWord(ti) {
const cp = (ti + 1) * 3; let cumul = 0;
for (let wi = 0; wi < words.length; wi++) { cumul += words[wi].length + 1; if (cp <= cumul) return Math.min(wi + 1, words.length - 1); }
return words.length - 1;
}
const N = triplets.length;
const iterX = [];
for (let ti = 0; ti < N; ti++) {
const chunk = quad.slice(ti * 24, Math.min((ti + 1) * 24, quad.length));
const len = chunk.length || 1;
const mb0 = chunk.reduce((a, q) => a + q[0], 0) / len;
const mb1 = chunk.reduce((a, q) => a + q[1], 0) / len;
const wi = tripletWord(ti);
const d = wordEndSet.has(ti) ? digests[Math.min(wi, digests.length - 1)] : 0.0;
iterX.push([mb0, mb1, d]);
}
const targets = Array.from({ length: N }, (_, ti) => nextWord(ti));
return { triplets, iterX, targets, words, N };
}

// ── Seeded RNG ────────────────────────────────────────────────────
let _rng = 42;
function resetRng(s = 42) { _rng = s >>> 0; }
function rand() { _rng = (Math.imul(_rng, 1664525) + 1013904223) >>> 0; return _rng / 0x100000000; }
function randn() {
const u = 1 - rand(), v = rand();
return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
}

// ── Minimal transformer (D=3) ─────────────────────────────────────
const DIM = 3, MLP_H = 128, CTX = 32, EPOCHS = 100, LR = 0.003;

function buildModel(Vw, Vt) {
const h = (r, c) => { const w = new Float64Array(r * c); const sc = Math.sqrt(2 / c); for (let i = 0; i < w.length; i++) w[i] = randn() * sc; return w; };
const sm = (r, c) => { const w = new Float64Array(r * c); for (let i = 0; i < w.length; i++) w[i] = randn() * 0.02; return w; };
const z = n => new Float64Array(n);
return {
E: h(Vt, DIM), mE: z(Vt*DIM), vE: z(Vt*DIM),
Wq: sm(DIM,DIM), mWq: z(DIM*DIM), vWq: z(DIM*DIM),
Wk: sm(DIM,DIM), mWk: z(DIM*DIM), vWk: z(DIM*DIM),
Wv: sm(DIM,DIM), mWv: z(DIM*DIM), vWv: z(DIM*DIM),
Wo: sm(DIM,DIM), mWo: z(DIM*DIM), vWo: z(DIM*DIM),
W1: h(DIM,MLP_H),  mW1: z(DIM*MLP_H),  vW1: z(DIM*MLP_H),  b1: z(MLP_H), mb1: z(MLP_H), vb1: z(MLP_H),
W2: h(MLP_H,DIM),  mW2: z(MLP_H*DIM),  vW2: z(MLP_H*DIM),  b2: z(DIM),   mb2: z(DIM),   vb2: z(DIM),
Wp: sm(DIM,Vw),    mWp: z(DIM*Vw),      vWp: z(DIM*Vw),
t: 0, Vw, Vt,
};
}

function smx(arr, n) {
let mx = -Infinity; for (let i = 0; i < n; i++) if (arr[i] > mx) mx = arr[i];
let s = 0; const o = new Float64Array(n);
for (let i = 0; i < n; i++) { o[i] = Math.exp(arr[i] - mx); s += o[i]; }
for (let i = 0; i < n; i++) o[i] /= s;
return o;
}

function adam(p, g, m, v, t, lr) {
const b1=0.9, b2=0.999, eps=1e-8, bc1=1-b1**t, bc2=1-b2**t;
for (let i = 0; i < p.length; i++) {
const gi = Math.max(-1, Math.min(1, g[i]));
m[i] = b1*m[i]+(1-b1)*gi; v[i] = b2*v[i]+(1-b2)*gi*gi;
p[i] -= lr*(m[i]/bc1)/(Math.sqrt(v[i]/bc2)+eps);
}
}

function runEpoch(model, iterX, triIds, targets, useFixed, train) {
const N = targets.length, Vw = model.Vw, sc = Math.sqrt(DIM);
const stride = Math.max(1, Math.floor(CTX / 2));
