// ═══════════════════════════════════════════════════════════
// ITERATOR CORE
// ═══════════════════════════════════════════════════════════
const C_F=1.094, DELTA=0.002, PREC=14;
function tr(x){const s=Math.pow(10,PREC);const r=Math.round(x*s)/s;return r>=0?Math.floor(r*s)/s:Math.ceil(r*s)/s;}
function textBits(s){const bits=[];for(const ch of s.toLowerCase()){const c=ch.charCodeAt(0);for(let i=7;i>=0;i--)bits.push((c>>i)&1);}return bits;}
function encodeF(bits){return bits.concat([0,0]).map(b=>C_F+(b?DELTA:0));}
function dStar(word,seed=0.085){
  const bits=textBits(word);
  let s=seed,prev=-999;
  for(let it=0;it<20;it++){
    const FSeq=encodeF(bits);let h=tr(s);
    for(const F of FSeq)h=tr((h*h-F)*(h*h-F)-F);
    if(Math.abs(h-prev)<1e-15)return h;
    prev=h;s=h;
  }
  return prev;
}

// ═══════════════════════════════════════════════════════════
// TOKEN ENCODING  D=32 per word
// ═══════════════════════════════════════════════════════════
const DIM=32;
function wordToVec(word){
  const v=new Float32Array(DIM);
  const s=word.toLowerCase();
  for(let i=0;i<Math.min(s.length,DIM-1);i++)v[i]=s.charCodeAt(i)/255.0;
  const digestSlot=Math.min(s.length,DIM-1);
  v[digestSlot]=dStar(word);
  return v;
}

