// ═══════════════════════════════════════════════════════════
// BUILD DATA
// ═══════════════════════════════════════════════════════════
function buildData(text){
  const words=text.toLowerCase().match(/[a-z']+/g)||[];
  const X=words.map(w=>wordToVec(w));
  return {words,X,N:words.length};
}

// ═══════════════════════════════════════════════════════════
// RNG
// ═══════════════════════════════════════════════════════════
let _rng=42;
function resetRng(s=42){_rng=s>>>0;}
function rand(){_rng=(((_rng*1664525)>>>0)+1013904223)>>>0;return _rng/0x100000000;}
function randn(){const u=1-rand(),v=rand();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);}

// ═══════════════════════════════════════════════════════════
// MODEL  CTX=32 words, QKV dim=16, MLP hidden=256
// ═══════════════════════════════════════════════════════════
const CTX=32,DK=16,DV=16,MLP_H=256,EPOCHS=100,LR=2e-4;
const IN_DIM=CTX*DV;

function buildAttn(){
  const h=(r,c)=>{const w=new Float32Array(r*c);const sc=Math.sqrt(2/c);for(let i=0;i<w.length;i++)w[i]=randn()*sc;return w;};
  return{
    WQ:h(DK,DIM),mWQ:new Float32Array(DK*DIM),vWQ:new Float32Array(DK*DIM),
    WK:h(DK,DIM),mWK:new Float32Array(DK*DIM),vWK:new Float32Array(DK*DIM),
    WV:h(DV,DIM),mWV:new Float32Array(DV*DIM),vWV:new Float32Array(DV*DIM),
    t:0,
  };
}

function buildMLP(Vw){
  const h=(r,c)=>{const w=new Float32Array(r*c);const sc=Math.sqrt(2/c);for(let i=0;i<w.length;i++)w[i]=randn()*sc;return w;};
  const z=n=>new Float32Array(n);
  return{
    W1:h(MLP_H,IN_DIM),b1:z(MLP_H),
    W2:h(MLP_H,MLP_H), b2:z(MLP_H),
    W3:h(Vw,MLP_H),    b3:z(Vw),
    mW1:z(MLP_H*IN_DIM),vW1:z(MLP_H*IN_DIM),
    mb1:z(MLP_H),vb1:z(MLP_H),
    mW2:z(MLP_H*MLP_H),vW2:z(MLP_H*MLP_H),
    mb2:z(MLP_H),vb2:z(MLP_H),
    mW3:z(Vw*MLP_H),vW3:z(Vw*MLP_H),
    mb3:z(Vw),vb3:z(Vw),
    t:0,Vw,
  };
}

function smx(arr,n){
  let mx=-Infinity;for(let i=0;i<n;i++)if(arr[i]>mx)mx=arr[i];
  let s=0;const o=new Float32Array(n);
  for(let i=0;i<n;i++){o[i]=Math.exp(arr[i]-mx);s+=o[i];}
  for(let i=0;i<n;i++)o[i]/=s;
  return o;
}
function relu(x){return x>0?x:0;}
function adam(p,g,m,v,t,lr){
  const b1=0.9,b2=0.999,eps=1e-8,bc1=1-Math.pow(b1,t),bc2=1-Math.pow(b2,t);
  for(let i=0;i<p.length;i++){
    const gi=Math.max(-1,Math.min(1,g[i]));
    m[i]=b1*m[i]+(1-b1)*gi;v[i]=b2*v[i]+(1-b2)*gi*gi;
    p[i]-=lr*(m[i]/bc1)/(Math.sqrt(v[i]/bc2)+eps);
  }
}

function matmul(W,x,rows,cols){
  const o=new Float32Array(rows);
  for(let i=0;i<rows;i++){let s=0;for(let j=0;j<cols;j++)s+=W[i*cols+j]*x[j];o[i]=s;}
  return o;
}

function attnFwd(a,seq){
  const N=seq.length;
  const Q=seq.map(x=>matmul(a.WQ,x,DK,DIM));
  const K=seq.map(x=>matmul(a.WK,x,DK,DIM));
  const V=seq.map(x=>matmul(a.WV,x,DV,DIM));
  const sc=Math.sqrt(DK);
  const weights=Q.map(q=>smx(K.map(k=>q.reduce((s,v,i)=>s+v*k[i],0)/sc),N));
  const attended=weights.map(w=>w.reduce((acc,wi,j)=>acc.map((v,d)=>v+wi*V[j][d]),new Array(DV).fill(0)));
  return{Q,K,V,weights,attended};
}

function attnBwd(a,seq,fwd,dAtt){
  const N=seq.length;const{Q,K,V,weights}=fwd;
  const sc=Math.sqrt(DK);
  const dWQ=new Float32Array(DK*DIM),dWK=new Float32Array(DK*DIM),dWV=new Float32Array(DV*DIM);
  for(let i=0;i<N;i++){
    for(let j=0;j<N;j++)for(let d=0;d<DV;d++){
      const g=weights[i][j]*dAtt[i][d];
      for(let k=0;k<DIM;k++)dWV[d*DIM+k]+=g*seq[j][k];
    }
    const dW=new Array(N).fill(0);
    for(let j=0;j<N;j++)for(let d=0;d<DV;d++)dW[j]+=dAtt[i][d]*V[j][d];
    const dS=weights[i].map((w,j)=>{let s=0;for(let k=0;k<N;k++)s+=weights[i][k]*dW[k];return w*(dW[j]-s)/sc;});
    const dQi=new Array(DK).fill(0);
    for(let j=0;j<N;j++)for(let d=0;d<DK;d++)dQi[d]+=dS[j]*K[j][d];
    for(let d=0;d<DK;d++)for(let k=0;k<DIM;k++)dWQ[d*DIM+k]+=dQi[d]*seq[i][k];
    for(let j=0;j<N;j++)for(let d=0;d<DK;d++)for(let k=0;k<DIM;k++)dWK[d*DIM+k]+=dS[j]*Q[i][d]*seq[j][k];
  }
  a.t++;
  adam(a.WQ,dWQ,a.mWQ,a.vWQ,a.t,LR);
  adam(a.WK,dWK,a.mWK,a.vWK,a.t,LR);
  adam(a.WV,dWV,a.mWV,a.vWV,a.t,LR);
}

function mlpFwdBwd(m,x,target){
  const z1=matmul(m.W1,x,MLP_H,IN_DIM).map((v,i)=>v+m.b1[i]);
  const a1=z1.map(relu);
  const z2=matmul(m.W2,a1,MLP_H,MLP_H).map((v,i)=>v+m.b2[i]);
  const a2=z2.map(relu);
  const z3=matmul(m.W3,a2,m.Vw,MLP_H).map((v,i)=>v+m.b3[i]);
  const probs=smx(z3,m.Vw);
  const loss=-Math.log(probs[target]+1e-10);
  // backward
  const dz3=Array.from(probs).map((p,i)=>p-(i===target?1:0));
  const dW3=new Float32Array(m.Vw*MLP_H);
  for(let i=0;i<m.Vw;i++)for(let j=0;j<MLP_H;j++)dW3[i*MLP_H+j]=dz3[i]*a2[j];
  const da2=new Float32Array(MLP_H);
  for(let j=0;j<MLP_H;j++)for(let i=0;i<m.Vw;i++)da2[j]+=m.W3[i*MLP_H+j]*dz3[i];
  const dz2=da2.map((v,i)=>v*(z2[i]>0?1:0));
  const dW2=new Float32Array(MLP_H*MLP_H);
  for(let i=0;i<MLP_H;i++)for(let j=0;j<MLP_H;j++)dW2[i*MLP_H+j]=dz2[i]*a1[j];
  const da1=new Float32Array(MLP_H);
  for(let j=0;j<MLP_H;j++)for(let i=0;i<MLP_H;i++)da1[j]+=m.W2[i*MLP_H+j]*dz2[i];
  const dz1=da1.map((v,i)=>v*(z1[i]>0?1:0));
  const dW1=new Float32Array(MLP_H*IN_DIM);
  for(let i=0;i<MLP_H;i++)for(let j=0;j<IN_DIM;j++)dW1[i*IN_DIM+j]=dz1[i]*x[j];
  const dx=new Float32Array(IN_DIM);
  for(let j=0;j<IN_DIM;j++)for(let i=0;i<MLP_H;i++)dx[j]+=m.W1[i*IN_DIM+j]*dz1[i];
  m.t++;
  adam(m.W3,dW3,m.mW3,m.vW3,m.t,LR);
  adam(m.b3,dz3,m.mb3,m.vb3,m.t,LR);
  adam(m.W2,dW2,m.mW2,m.vW2,m.t,LR);
  adam(m.b2,dz2,m.mb2,m.vb2,m.t,LR);
  adam(m.W1,dW1,m.mW1,m.vW1,m.t,LR);
  adam(m.b1,dz1,m.mb1,m.vb1,m.t,LR);
  return{loss,dx:Array.from(dx)};
}

// ═══════════════════════════════════════════════════════════
// APP STATE
// ═══════════════════════════════════════════════════════════
let state={status:'idle',running:false,epoch:0,lossT:[],lossE:[],log:[],finals:null};

function $(id){return document.getElementById(id);}

function addLog(msg,cls=''){
  state.log.push({msg,cls});
  const box=$('log-box');
  const d=document.createElement('div');
  d.className='log-line'+(cls?' '+cls:'');
  d.textContent=msg;
  box.appendChild(d);
  box.scrollTop=box.scrollHeight;
}

function setStatus(s,label){
  state.status=s;
  const dot=$('status-dot');
  dot.className='status-dot '+s;
  $('status-text').textContent=label;
  $('btn-run').disabled=s==='running'||s==='init';
  $('btn-stop').disabled=s!=='running'&&s!=='init';
}

function renderChart(){
  const T=state.lossT,E=state.lossE;
  if(!T.length)return;
  const W=552,H=170,PL=40,PR=12,PT=12,PB=26;
  const cW=W-PL-PR,cH=H-PT-PB;
  const all=[...T,...E];
  const minL=Math.min(...all)*0.95,maxL=Math.max(...all)*1.03;
  const n=T.length;
  const xS=i=>PL+(i/Math.max(n-1,1))*cW;
  const yS=v=>PT+(1-(v-minL)/(maxL-minL+1e-9))*cH;
  function path(data,color,dash){
    const d=data.map((v,i)=>`${i===0?'M':'L'}${xS(i).toFixed(1)},${yS(v).toFixed(1)}`).join(' ');
    const p=document.createElementNS('http://www.w3.org/2000/svg','path');
    p.setAttribute('d',d);p.setAttribute('fill','none');p.setAttribute('stroke',color);
    p.setAttribute('stroke-width',dash?'1.5':'2');p.setAttribute('stroke-linecap','round');
    if(dash)p.setAttribute('stroke-dasharray',dash);
    return p;
  }
  function el(tag,attrs){const e=document.createElementNS('http://www.w3.org/2000/svg',tag);Object.entries(attrs).forEach(([k,v])=>e.setAttribute(k,v));return e;}
  function txt(attrs,text){const e=el('text',attrs);e.textContent=text;return e;}
  const svg=document.createElementNS('http://www.w3.org/2000/svg','svg');
  svg.setAttribute('viewBox',`0 0 ${W} ${H}`);svg.style.cssText='display:block;width:100%;height:auto;';
  svg.appendChild(el('rect',{width:W,height:H,fill:'white'}));
  // grid
  [0,0.25,0.5,0.75,1].forEach(t=>{
    const v=minL+(maxL-minL)*t,y=yS(v);
    svg.appendChild(el('line',{x1:PL,y1:y,x2:PL+cW,y2:y,stroke:'#f0f0f5'}));
    svg.appendChild(txt({x:PL-4,y:y+4,'text-anchor':'end','font-size':'9',fill:'#aeaeb2','font-family':'system-ui'},v.toFixed(2)));
  });
  [20,40,60,80,100].filter(e=>e<=n).forEach(e=>{
    svg.appendChild(el('line',{x1:xS(e-1),y1:PT,x2:xS(e-1),y2:PT+cH,stroke:'#f5f5f7'}));
    svg.appendChild(txt({x:xS(e-1),y:PT+cH+14,'text-anchor':'middle','font-size':'9',fill:'#aeaeb2','font-family':'system-ui'},e));
  });
  svg.appendChild(el('line',{x1:PL,y1:PT,x2:PL,y2:PT+cH,stroke:'#e5e5ea'}));
  svg.appendChild(el('line',{x1:PL,y1:PT+cH,x2:PL+cW,y2:PT+cH,stroke:'#e5e5ea'}));
  svg.appendChild(path(T,'#1c1c1e','4,3'));
  svg.appendChild(path(E,'#e53935'));
  if(E.length){
    const v=E[E.length-1];
    svg.appendChild(el('circle',{cx:xS(E.length-1),cy:yS(v),r:'3.5',fill:'#e53935'}));
    svg.appendChild(txt({x:xS(E.length-1)+6,y:yS(v)+4,'font-size':'10',fill:'#e53935','font-weight':'600','font-family':'system-ui'},v.toFixed(3)));
  }
  if(T.length){
    const v=T[T.length-1];
    svg.appendChild(el('circle',{cx:xS(T.length-1),cy:yS(v),r:'3.5',fill:'#1c1c1e'}));
    svg.appendChild(txt({x:xS(T.length-1)+6,y:yS(v)+4,'font-size':'10',fill:'#1c1c1e','font-weight':'600','font-family':'system-ui'},v.toFixed(3)));
  }
  const area=$('chart-area');
  area.innerHTML='';area.style.height='';area.appendChild(svg);
  $('chart-title').textContent=`Loss · train (dashed) · test / Alice (solid) · ep ${state.epoch}/100`;
}

function updateResults(){
  const f=state.finals;if(!f)return;
  $('result-grid').style.display='';
  $('train-loss').textContent=f.trL.toFixed(4);
  $('train-signal').textContent=`signal ${f.sigT.toFixed(4)} nats`;
  $('test-loss').textContent=f.teL.toFixed(4);
  $('test-signal').textContent=`signal ${f.sigE.toFixed(4)} nats`;
  const gap=f.teL-f.trL;
  const gapEl=$('test-gap');
  gapEl.textContent=`gap ${gap>=0?'+':''}${gap.toFixed(4)}`;
  gapEl.style.color=gap<0?'#34c759':'#ff9500';
}

// ═══════════════════════════════════════════════════════════
// TRAINING
// ═══════════════════════════════════════════════════════════
async function runTraining(){
  if(state.running)return;
  state.running=true;state.epoch=0;state.lossT=[];state.lossE=[];state.finals=null;
  setStatus('init','Building…');

  addLog('Word-Level Digest · D=32 · Unlearned Fixed Input','info');
  addLog('Building train corpus (Genesis Ch.1–10)…');
  await new Promise(r=>setTimeout(r,80));
  const tr=buildData(GENESIS);

  addLog('Building test corpus (Alice Ch.I)…');
  await new Promise(r=>setTimeout(r,60));
  const te=buildData(ALICE);

  addLog('Building vocab & models…');
  await new Promise(r=>setTimeout(r,60));

  const vocab=[...new Set(tr.words)].sort();
  const w2i=Object.fromEntries(vocab.map((w,i)=>[w,i]));
  const Vw=vocab.length;
  const logVw=Math.log(Vw);

  addLog(`Train: ${tr.N} words · Test: ${te.N} words · Vw=${Vw} · random=${logVw.toFixed(4)}`);
  addLog(`D=${DIM} · CTX=${CTX} words · QKV(${DK}/${DV}) · flat(${IN_DIM}d) · ${MLP_H}×2 MLP`);
  addLog('─────────────────────────────────────────────────','sep');

  resetRng(42);
  const attn=buildAttn();
  const mlp=buildMLP(Vw);

  setStatus('running','Training…');

  for(let ep=0;ep<EPOCHS;ep++){
    if(!state.running)break;

    // shuffle word pairs for train
    const pairs=[];
    for(let i=0;i<tr.N-1;i++) pairs.push(i);
    pairs.sort(()=>rand()-0.5);

    let sumLtr=0,cnt=0;
    for(let b=0;b<pairs.length;b+=16){
      if(!state.running)break;
      const batch=pairs.slice(b,Math.min(b+16,pairs.length));
      for(const wi of batch){
        const target=(w2i[tr.words[wi+1]]!==undefined?w2i[tr.words[wi+1]]:0);
        const start=Math.max(0,wi-CTX+1);
        const ctx=tr.X.slice(start,wi+1);
        while(ctx.length<CTX)ctx.unshift(new Float32Array(DIM));
        const fwd=attnFwd(attn,ctx);
        const flat=new Float32Array(CTX*DV);
        fwd.attended.forEach((v,i)=>v.forEach((x,d)=>flat[i*DV+d]=x));
        const{loss,dx}=mlpFwdBwd(mlp,flat,target);
        sumLtr+=isFinite(loss)?loss:0;cnt++;
        const dAttn=[];
        for(let k=0;k<CTX;k++)dAttn.push(dx.slice(k*DV,(k+1)*DV));
        attnBwd(attn,ctx,fwd,dAttn);
      }
      if(b%(16*8)===0)await new Promise(r=>setTimeout(r,0));
    }
    const avgLtr=sumLtr/Math.max(cnt,1);

    // eval on test (no grad)
    let sumLte=0,cnte=0;
    for(let wi=0;wi<te.N-1;wi++){
      const target=(w2i[te.words[wi+1]]!==undefined?w2i[te.words[wi+1]]:0);
      const start=Math.max(0,wi-CTX+1);
      const ctx=te.X.slice(start,wi+1);
      while(ctx.length<CTX)ctx.unshift(new Float32Array(DIM));
      const fwd=attnFwd(attn,ctx);
      const flat=new Float32Array(CTX*DV);
      fwd.attended.forEach((v,i)=>v.forEach((x,d)=>flat[i*DV+d]=x));
      const z1=matmul(mlp.W1,flat,MLP_H,IN_DIM).map((v,i)=>relu(v+mlp.b1[i]));
      const z2=matmul(mlp.W2,z1,MLP_H,MLP_H).map((v,i)=>relu(v+mlp.b2[i]));
      const z3=matmul(mlp.W3,z2,Vw,MLP_H).map((v,i)=>v+mlp.b3[i]);
      const p=smx(z3,Vw);
      const loss=-Math.log(p[target]+1e-10);
      sumLte+=isFinite(loss)?loss:0;cnte++;
    }
    const avgLte=sumLte/Math.max(cnte,1);

    state.lossT.push(avgLtr);state.lossE.push(avgLte);
    state.epoch=ep+1;
    state.finals={trL:avgLtr,teL:avgLte,sigT:logVw-avgLtr,sigE:logVw-avgLte};
    $('epoch-text').textContent=`ep ${ep+1}/100`;
    renderChart();updateResults();

    const m=(ep+1)%10===0;
    addLog(`Ep${String(ep+1).padStart(3)}  tr=${avgLtr.toFixed(4)}  te=${avgLte.toFixed(4)}  gap=${(avgLte-avgLtr>=0?'+':'')}${(avgLte-avgLtr).toFixed(4)}${m?' ◆':''}`,m?'hi':'');
    if(m)await new Promise(r=>setTimeout(r,0));
  }

  const f=state.finals;
  addLog('─────────────────────────────────────────────────','sep');
  addLog(`FINAL  train=${f.trL.toFixed(4)}  test=${f.teL.toFixed(4)}  gap=${(f.teL-f.trL>=0?'+':'')}${(f.teL-f.trL).toFixed(4)}`,'hi');
  addLog(`Signal train=${f.sigT.toFixed(4)}  test=${f.sigE.toFixed(4)}  random=${Math.log(f.sigT+f.trL).toFixed(4)}`,'hi');

  state.running=false;
  setStatus('done','Complete');
}

// ═══════════════════════════════════════════════════════════
// CONTROLS
// ═══════════════════════════════════════════════════════════
$('btn-run').onclick=()=>runTraining();
$('btn-stop').onclick=()=>{state.running=false;setStatus('idle','Stopped');};
$('btn-reset').onclick=()=>{
  state.running=false;state.epoch=0;state.lossT=[];state.lossE=[];state.log=[];state.finals=null;
  $('log-box').innerHTML='';$('result-grid').style.display='none';
  $('chart-area').innerHTML='train (solid) · test (dashed)';
  $('chart-area').style.height='180px';
  $('epoch-text').textContent='';$('chart-title').textContent='Loss curve — press Run to begin';
  setStatus('idle','Ready');
};
$('btn-copy').onclick=()=>{
  navigator.clipboard.writeText(state.log.map(l=>l.msg).join('\n'))
    .then(()=>{$('btn-copy').textContent='Copied ✓';setTimeout(()=>$('btn-copy').textContent='Copy Log',2000);});
};
</script>

