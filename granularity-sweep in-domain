<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #f2f2f7;
    font-family: -apple-system, 'SF Pro Display', 'SF Pro Text', system-ui, sans-serif;
    padding: 24px 16px 48px;
    -webkit-font-smoothing: antialiased;
  }
  .card {
    background: white;
    border-radius: 20px;
    max-width: 640px;
    margin: 0 auto;
    overflow: hidden;
    box-shadow: 0 4px 32px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
  }

/* ── Header ── */
.header {
padding: 28px 28px 20px;
border-bottom: 1px solid #f0f0f5;
}
.eyebrow {
font-size: 10px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: #aeaeb2;
margin-bottom: 8px;
}
.title {
font-size: 22px;
font-weight: 700;
color: #1c1c1e;
letter-spacing: -0.02em;
line-height: 1.2;
margin-bottom: 4px;
}
.subtitle {
font-size: 13px;
color: #8e8e93;
line-height: 1.5;
margin-bottom: 14px;
}
.meta-row {
display: flex;
gap: 6px;
flex-wrap: wrap;
}
.pill {
background: #f2f2f7;
border-radius: 20px;
padding: 4px 10px;
font-size: 11px;
color: #6e6e73;
font-weight: 500;
}

/* ── Section ── */
.section {
padding: 20px 28px;
border-bottom: 1px solid #f0f0f5;
}
.section:last-child { border-bottom: none; }
.section-title {
font-size: 11px;
font-weight: 600;
letter-spacing: 0.08em;
text-transform: uppercase;
color: #aeaeb2;
margin-bottom: 14px;
}

/* ── 2×2 chart grid ── */
.chart-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
}
.chart-cell {
background: #f9f9fb;
border-radius: 12px;
padding: 10px 10px 6px;
overflow: hidden;
}
.chart-cell-title {
font-size: 11px;
font-weight: 600;
color: #3a3a3c;
margin-bottom: 2px;
}
.chart-cell-desc {
font-size: 9px;
color: #aeaeb2;
margin-bottom: 6px;
}
.chart-cell svg {
display: block;
width: 100%;
height: auto;
}

/* ── Gap table ── */
.gap-table {
width: 100%;
border-collapse: collapse;
font-size: 12px;
}
.gap-table th {
font-size: 10px;
font-weight: 600;
color: #aeaeb2;
text-align: left;
padding: 0 10px 8px 0;
letter-spacing: 0.05em;
text-transform: uppercase;
}
.gap-table th:not(:first-child) { text-align: right; }
.gap-table td {
padding: 7px 10px 7px 0;
border-top: 1px solid #f0f0f5;
color: #3a3a3c;
font-variant-numeric: tabular-nums;
}
.gap-table td:not(:first-child) { text-align: right; }
.gap-table tr:first-child td { border-top: none; }
.res-label {
font-weight: 700;
color: #1c1c1e;
font-size: 13px;
}
.res-desc { font-size: 10px; color: #aeaeb2; }
.gap-c { color: #e53935; font-weight: 600; }
.gap-r { color: #43a047; font-weight: 600; }
.gap-a { color: #1e88e5; font-weight: 600; }
.gap-cr { font-weight: 700; }
.gap-cr.neg { color: #43a047; }
.gap-cr.pos { color: #ff9500; }

/* ── Finding ── */
.finding-row {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
margin-top: 14px;
}
.finding-cell {
background: #f9f9fb;
border-radius: 12px;
padding: 12px 14px;
}
.finding-label {
font-size: 10px;
font-weight: 600;
color: #aeaeb2;
text-transform: uppercase;
letter-spacing: 0.08em;
margin-bottom: 4px;
}
.finding-value {
font-size: 15px;
font-weight: 700;
color: #1c1c1e;
line-height: 1.2;
margin-bottom: 3px;
}
.finding-sub {
font-size: 11px;
color: #8e8e93;
line-height: 1.4;
}

/* ── Legend ── */
.legend {
display: flex;
gap: 16px;
font-size: 11px;
color: #8e8e93;
margin-bottom: 12px;
flex-wrap: wrap;
}
.legend-item { display: flex; align-items: center; gap: 5px; }
.legend-dot {
width: 8px; height: 8px; border-radius: 50%;
flex-shrink: 0;
}
.legend-line-solid {
width: 20px; height: 2px; border-radius: 1px; flex-shrink: 0;
}
.legend-line-dash {
width: 20px; height: 0; border-top: 2px dashed;
flex-shrink: 0; opacity: 0.5;
}

/* ── Footer ── */
.footer {
padding: 16px 28px;
background: #f9f9fb;
border-top: 1px solid #f0f0f5;
display: flex;
justify-content: space-between;
align-items: center;
flex-wrap: wrap;
gap: 8px;
}
.footer-author {
font-size: 12px;
font-weight: 600;
color: #3a3a3c;
}
.footer-date {
font-size: 11px;
color: #aeaeb2;
}
