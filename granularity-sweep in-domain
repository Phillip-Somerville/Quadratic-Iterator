// ── SVG helper ────────────────────────────────────────────────────
function el(tag, attrs, children) {
  const e = document.createElementNS('http://www.w3.org/2000/svg', tag);
  if (attrs) Object.entries(attrs).forEach(([k,v]) => e.setAttribute(k, v));
  if (children) children.forEach(c => e.appendChild(c));
  return e;
}
function txt(tag, attrs, text) {
  const e = el(tag, attrs);
  e.textContent = text;
  return e;
}

function makeCurveChart(run) {
  const W=260, H=130, PL=28, PR=8, PT=8, PB=18;
  const cW=W-PL-PR, cH=H-PT-PB;

  const all = [...run.trC, ...run.teC, ...run.teA, ...run.teR];
  const minL = Math.min(...all)*0.98;
  const maxL = Math.max(...all)*1.02;
  const n = run.trC.length;

  const xS = i => PL + (i/Math.max(n-1,1))*cW;
  const yS = v => PT + (1-(v-minL)/(maxL-minL+1e-9))*cH;

  function path(data, color, dash) {
    if (!data || !data.length) return null;
    const d = data.map((v,i) => `${i===0?'M':'L'}${xS(i).toFixed(1)},${yS(v).toFixed(1)}`).join(' ');
    const p = el('path', {d, fill:'none', stroke:color, 'stroke-width': dash?'1':'1.5', 'stroke-linecap':'round'});
    if (dash) p.setAttribute('stroke-dasharray', dash);
    p.setAttribute('opacity', dash ? '0.4' : '1');
    return p;
  }

  const svg = el('svg', {viewBox:`0 0 ${W} ${H}`, xmlns:'http://www.w3.org/2000/svg'});
  svg.style.cssText = 'display:block;width:100%;height:auto;';
  svg.appendChild(el('rect', {width:W, height:H, fill:'#f9f9fb', rx:'8'}));

  // grid lines
  [0, 0.5, 1].forEach(t => {
    const v = minL + (maxL-minL)*t;
    const y = yS(v);
    svg.appendChild(el('line', {x1:PL, y1:y, x2:PL+cW, y2:y, stroke:'#e5e5ea'}));
    svg.appendChild(txt('text', {x:PL-3, y:y+3, 'text-anchor':'end', 'font-size':'7', fill:'#c7c7cc', 'font-family':'system-ui'}, v.toFixed(1)));
  });

  // epoch ticks
  [25,50,75,100].filter(e => e <= n).forEach(e => {
    svg.appendChild(el('line', {x1:xS(e-1), y1:PT, x2:xS(e-1), y2:PT+cH, stroke:'#e5e5ea'}));
    svg.appendChild(txt('text', {x:xS(e-1), y:PT+cH+11, 'text-anchor':'middle', 'font-size':'7', fill:'#c7c7cc', 'font-family':'system-ui'}, e));
  });

  svg.appendChild(el('line', {x1:PL, y1:PT, x2:PL, y2:PT+cH, stroke:'#e5e5ea'}));
  svg.appendChild(el('line', {x1:PL, y1:PT+cH, x2:PL+cW, y2:PT+cH, stroke:'#e5e5ea'}));

  // train dashed
  svg.appendChild(path(run.trC, '#e53935', '3,2'));

  // test solid
  svg.appendChild(path(run.teR, '#43a047'));
  svg.appendChild(path(run.teA, '#1e88e5'));
  svg.appendChild(path(run.teC, '#e53935'));

  // end dots + labels
  [[run.teC,'#e53935'],[run.teA,'#1e88e5'],[run.teR,'#43a047']].forEach(([data,color]) => {
    if (!data || !data.length) return;
    const v = data[data.length-1];
    svg.appendChild(el('circle', {cx:xS(data.length-1), cy:yS(v), r:'2.5', fill:color}));
  });

  return svg;
}

// ── Render charts ─────────────────────────────────────────────────
const grid = document.getElementById('chart-grid');
RUNS.forEach(run => {
  const cell = document.createElement('div');
  cell.className = 'chart-cell';
  cell.innerHTML = `<div class="chart-cell-title">${run.label}</div><div class="chart-cell-desc">${run.bits} bit${run.bits>1?'s':''} per token · ${run.desc}</div>`;
  cell.appendChild(makeCurveChart(run));
  grid.appendChild(cell);
});

// ── Render gap table ──────────────────────────────────────────────
const tbody = document.getElementById('gap-tbody');
RUNS.forEach(run => {
  const cr = run.gapC - run.gapR;
  const crClass = cr < 0 ? 'neg' : 'pos';
  const tr = document.createElement('tr');
  tr.innerHTML = `
    <td>
      <span class="res-label">${run.label}</span><br>
      <span class="res-desc">${run.desc}</span>
    </td>
    <td class="gap-c">${run.gapC >= 0 ? '+' : ''}${run.gapC.toFixed(4)}</td>
    <td class="gap-r">${run.gapR >= 0 ? '+' : ''}${run.gapR.toFixed(4)}</td>
    <td class="gap-a">${run.gapA >= 0 ? '+' : ''}${run.gapA.toFixed(4)}</td>
    <td class="gap-cr ${crClass}">${cr >= 0 ? '+' : ''}${cr.toFixed(4)}</td>
  `;
  tbody.appendChild(tr);
});
