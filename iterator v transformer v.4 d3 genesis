// ── Iterator core ─────────────────────────────────────────────────
const C_F = 1.094, DELTA = 0.002, PREC = 14;

function tr(x) {
const s = 10 ** PREC;
const r = Math.round(x * s) / s;
return r >= 0 ? Math.floor(r * s) / s : Math.ceil(r * s) / s;
}
function textBits(s) {
const bits = [];
for (const ch of s.toLowerCase()) {
const code = ch.charCodeAt(0);
for (let i = 7; i >= 0; i–) bits.push((code >> i) & 1);
}
return bits;
}
function encodeF(bits) { return […bits, 0, 0].map(b => C_F + (b ? DELTA : 0)); }
function quadChannel(FSeq) {
const ch = []; let prev = null;
for (const F of FSeq) {
if (prev === null)                  ch.push([0, 0]);
else if (F === C_F && prev > C_F)   ch.push([0, 0]);
else if (F === C_F && prev === C_F) ch.push([0, 1]);
else if (F > C_F  && prev > C_F)    ch.push([1, 0]);
else if (F > C_F  && prev === C_F)  ch.push([1, 1]);
else                                ch.push([0, 1]);
prev = F;
}
return ch;
}
function dStar(bits, seed = 0.085) {
let s = seed, prev = -999;
for (let it = 0; it < 20; it++) {
const FSeq = encodeF(bits); let h = tr(s);
for (const F of FSeq) h = tr((h * h - F) ** 2 - F);
if (Math.abs(h - prev) < 1e-15) return h;
prev = h; s = h;
}
return prev;
}

